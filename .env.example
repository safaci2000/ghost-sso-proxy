# ghost-sso-proxy — copy to .env and fill in values for local development.
# The app loads this file automatically via godotenv on startup.
# In Kubernetes these are injected as environment variables from the Secret.

# ── Database ──────────────────────────────────────────────────────────────────
# Use 127.0.0.1 (not localhost) to force TCP; the driver treats "localhost"
# as a Unix socket path on Linux which won't work against Docker.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ghost
DB_USER=ghost
DB_PASSWORD=ghostpassword

# ── gRPC server ───────────────────────────────────────────────────────────────
GRPC_PORT=8080

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=debug

# ── OIDC ──────────────────────────────────────────────────────────────────────
# Userinfo endpoint of your OIDC provider. ExtAuth calls this with the Bearer
# access token to resolve the user's email. When empty, the decoder falls back
# to local JWT payload decoding (suitable for local dev with a raw JWT).
# OIDC_USERINFO_URL=https://auth.example.com/application/o/envoy-oidc/userinfo/
