# ── MariaDB ──────────────────────────────────────────────────────────────────
# These are consumed by the mariadb container image.
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=ghost
MYSQL_USER=ghost
MYSQL_PASSWORD=ghostpassword

# ── Ghost ─────────────────────────────────────────────────────────────────────
# Ghost reads these as double-underscore-namespaced config keys.
NODE_ENV=development
url=http://localhost:2368

database__client=mysql
database__connection__host=db
database__connection__port=3306
database__connection__database=ghost
database__connection__user=ghost
database__connection__password=ghostpassword
database__connection__charset=utf8mb4

# Use Ghost's direct transport in development — no SMTP needed.
# Sent mail appears in Ghost's stdout logs.
mail__transport=Direct
mail__from=ghost@localhost
